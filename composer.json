{
  "name": "remsana/backend-core",
  "description": "Remsana authoritative backend core (CodeIgniter 4)",
  "type": "project",
  "require": {
    "php": "^8.1",
    "codeigniter4/framework": "^4.5",
    "firebase/php-jwt": "^6.10",
    "pragmarx/google2fa": "^9.0"
  },
  "require-dev": {
    "fakerphp/faker": "^1.23",
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "migrate": "php spark migrate",
    "seed": "php spark db:seed"
  },
  "config": {
    "optimize-autoloader": true,
    "platform": {
      "php": "8.1"
    }
  }
}
